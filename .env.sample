# =============================================================================
# GPT Researcher - Environment Configuration (Sample)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env

# --- API Keys ---
# Set to "not-needed" if using local LLMs with no authentication
OPENAI_API_KEY=
TAVILY_API_KEY=

# --- Fast LLM (quick tasks: agent selection, small operations) ---
# Format: provider:model_name (e.g. openai:gpt-4o-mini, openai:llama-3.1-70b)
FAST_LLM=openai:gpt-4o-mini
# Optional: custom OpenAI-compatible endpoint for Fast LLM
# FAST_LLM_BASE_URL=http://localhost:8000/v1

# --- Smart LLM (report writing, general tasks) ---
SMART_LLM=openai:gpt-4o
# Optional: custom OpenAI-compatible endpoint for Smart LLM
# SMART_LLM_BASE_URL=http://localhost:8000/v1

# --- Strategic LLM (complex reasoning, sub-query planning, report writing) ---
STRATEGIC_LLM=openai:gpt-4o
# Optional: custom OpenAI-compatible endpoint for Strategic LLM
# STRATEGIC_LLM_BASE_URL=http://localhost:8001/v1

# --- Embedding Model ---
# Format: provider:model_name
EMBEDDING=openai:text-embedding-3-small
# Optional: custom OpenAI-compatible endpoint for embeddings
# EMBEDDING_BASE_URL=http://localhost:8002/v1

# --- Deep Research Settings ---
# depth: recursive depth levels (2 recommended for quick runs, 4 for thorough)
# breadth: search queries per level (2-4 recommended)
# concurrency: max parallel research tasks
DEEP_RESEARCH_DEPTH=2
DEEP_RESEARCH_BREADTH=2
DEEP_RESEARCH_CONCURRENCY=4

# --- General Settings ---
RETRIEVER=tavily
DOC_PATH=./my-docs
REPORT_SOURCE=web

# --- Optional: LangChain Tracing (LangSmith) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=gpt-researcher
